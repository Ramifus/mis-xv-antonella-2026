---
// Regalos.astro
---

<section class="relative w-full py-8 px-6">
  <!-- Flor lateral izquierda -->
  <div
    class="absolute left-0 top-1/2 -translate-y-1/2 w-12 md:w-20 lg:w-28 pointer-events-none z-0"
    id="flor-izq-regalo"
  >
    <img
      src="/imagenes/FlorLateral.webp"
      alt=""
      class="w-full h-auto object-contain"
    />
  </div>

  <!-- Flor lateral derecha -->
  <div
    class="absolute right-0 top-1/2 -translate-y-1/2 w-12 md:w-20 lg:w-28 pointer-events-none z-0"
    id="flor-der-regalo"
  >
    <img
      src="/imagenes/FlorLateral.webp"
      alt=""
      class="w-full h-auto object-contain scale-x-[-1]"
    />
  </div>

  <div class="max-w-sm lg:max-w-xl mx-auto text-center" id="contenedor-regalos">

    <!-- SEPARADOR SUPERIOR -->
    <div class="flex justify-center mb-6">
      <img
        src="/imagenes/Separador.png"
        alt="Separador decorativo"
        class="w-32 md:w-48 lg:w-56 h-auto object-contain icono-lila"
      />
    </div>

    <!-- TÍTULO -->
    <div class="mb-4" id="tarjeta-regalo">
      <h3
        class="font-charm text-[#5a1491] uppercase text-2xl md:text-3xl font-bold mb-4"
      >
        Sugerencia de Regalos
      </h3>

      <!-- Línea decorativa -->
      <div class="flex items-center justify-center gap-3 mb-6">
        <span
          class="block h-px w-16 sm:w-24"
          style="background:linear-gradient(to right, transparent, #C4869A);"
        ></span>
        <span style="color:#C4869A;">✦</span>
        <span
          class="block h-px w-16 sm:w-24"
          style="background:linear-gradient(to left, transparent, #C4869A);"
        ></span>
      </div>

      <!-- Texto -->
      <p
        class="font-charm text-lg md:text-2xl leading-relaxed"
        style="color:#C4869A;"
      >
        Tu presencia es mi mejor regalo, pero si deseas tener un detalle
        conmigo, puedes hacerlo a través del siguiente QR
      </p>
    </div>

    <!-- QR -->
    <div class="mt-6" id="tarjeta-qr">
      <h3
        class="font-charm text-[#5a1491] tracking-widest uppercase text-lg font-semibold mb-4"
      >
        Transferencia QR
      </h3>
      <div class="flex justify-center">
        <div class="relative group">
          <div
            class="w-52 h-52 bg-white rounded-2xl flex items-center justify-center border-2 border-[#5a1491]/20 shadow-sm transform transition-transform duration-300 group-hover:scale-105"
          >
            <img
              src="/imagenes/qr.png"
              alt="Código QR"
              class="w-full h-full object-contain rounded-lg"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Texto inferior -->
    <div class="mt-6" id="texto-inferior">
      <div
        class="font-charm text-lg md:text-xl leading-relaxed space-y-1"
        style="color:#C4869A;"
      >
        <p>
          <span class="text-[#5a1491] font-bold">Nombre:</span> Ramírez Contreras
          Jimena Claudia
        </p>
        <p><span class="text-[#5a1491] font-bold">Cuenta:</span> 1034521401</p>
        <p>
          <span class="text-[#5a1491] font-bold">Motivo:</span> Mis 15 años Antonella
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initRegalos = () => {
    gsap.set("#contenedor-regalos", { opacity: 0, y: 40 });
    gsap.set("#tarjeta-regalo", { opacity: 0, y: 20 });
    gsap.set("#tarjeta-qr", { opacity: 0, y: 30, scale: 0.95 });
    gsap.set("#texto-inferior", { opacity: 0, y: 20 });
    gsap.set("#flor-izq-regalo", { opacity: 0, x: -40 });
    gsap.set("#flor-der-regalo", { opacity: 0, x: 40 });

    ScrollTrigger.create({
      trigger: "#contenedor-regalos",
      start: "top 80%",
      onEnter: () => {
        const tl = gsap.timeline();
        tl.to("#contenedor-regalos", {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: "power2.out",
        })
          .to(
            "#flor-izq-regalo",
            { opacity: 1, x: 0, duration: 1, ease: "power2.out" },
            0,
          )
          .to(
            "#flor-der-regalo",
            { opacity: 1, x: 0, duration: 1, ease: "power2.out" },
            0,
          )
          .to(
            "#tarjeta-regalo",
            { opacity: 1, y: 0, duration: 0.7, ease: "power2.out" },
            "-=0.4",
          )
          .to(
            "#tarjeta-qr",
            {
              opacity: 1,
              y: 0,
              scale: 1,
              duration: 0.8,
              ease: "back.out(1.4)",
            },
            "-=0.3",
          )
          .to(
            "#texto-inferior",
            { opacity: 1, y: 0, duration: 0.7, ease: "power2.out" },
            "-=0.3",
          );
      },
      onLeaveBack: () => {
        gsap.set("#contenedor-regalos", { opacity: 0, y: 40 });
        gsap.set("#tarjeta-regalo", { opacity: 0, y: 20 });
        gsap.set("#tarjeta-qr", { opacity: 0, y: 30, scale: 0.95 });
        gsap.set("#texto-inferior", { opacity: 0, y: 20 });
        gsap.set("#flor-izq-regalo", { opacity: 0, x: -40 });
        gsap.set("#flor-der-regalo", { opacity: 0, x: 40 });
      },
    });
  };

  document.addEventListener("DOMContentLoaded", initRegalos);
  document.addEventListener("astro:page-load", initRegalos);
</script>

<style>
  .icono-lila {
    filter: brightness(0) saturate(100%) invert(16%) sepia(89%) saturate(3571%)
      hue-rotate(274deg) brightness(82%) contrast(108%);
  }
</style>
