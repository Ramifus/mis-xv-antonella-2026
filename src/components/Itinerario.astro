---
// Itinerario.astro - Quinceañera
---

<section class="px-4 relative overflow-hidden py-8">
  <div class="max-w-5xl mx-auto relative z-10">
    <div class="max-w-3xl mx-auto relative">
      <!-- TÍTULO -->
      <div class="text-center mb-4 titulo-itinerario opacity-0">
        <h2
          class="font-charm text-2xl md:text-3xl text-[#5a1491] font-bold mb-2"
        >
          ITINERARIO
        </h2>
        <div class="flex items-center justify-center gap-3">
          <span
            class="block h-px w-16"
            style="background:linear-gradient(to right, transparent, #C4869A);"
          ></span>
          <span style="color:#C4869A;">✦</span>
          <span
            class="block h-px w-16"
            style="background:linear-gradient(to left, transparent, #C4869A);"
          ></span>
        </div>
      </div>

      <div class="relative px-4 md:px-8">
        <!-- FLORES LATERALES IZQUIERDA -->
        <div
          class="absolute -left-4 md:-left-8 lg:-left-12 top-1/2 -translate-y-1/2 w-10 md:w-24 lg:w-28 pointer-events-none z-0 flor-lateral-izq opacity-0"
        >
          <img
            src="/imagenes/FlorLateral.webp"
            alt=""
            class="w-full h-auto object-contain"
          />
        </div>

        <!-- FLORES LATERALES DERECHA -->
        <div
          class="absolute -right-4 md:-right-8 lg:-right-12 top-1/2 -translate-y-1/2 w-10 md:w-24 lg:w-28 pointer-events-none z-0 flor-lateral-der opacity-0"
        >
          <img
            src="/imagenes/FlorLateral.webp"
            alt=""
            class="w-full h-auto object-contain scale-x-[-1]"
          />
        </div>

        <!-- LÍNEA VERTICAL CENTRAL -->
        <div
          class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[2px] rounded-full linea-central opacity-0"
          style="background: linear-gradient(to bottom, transparent, #C3A1D9 8%, #C3A1D9 92%, transparent);"
        >
        </div>

        <div class="space-y-0" id="eventos-container">
          <!-- Punto inicial -->
          <div class="flex justify-center py-0.5">
            <div
              class="w-5 h-5 rounded-full bg-gradient-to-br from-[#C3A1D9] to-[#a87cc7] flex items-center justify-center relative z-10 corazon-item shadow-sm opacity-0"
            >
              <svg
                class="w-3 h-3 text-white"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                ></path>
              </svg>
            </div>
          </div>

          <!-- EVENTO 1 -->
          <div
            class="evento-item grid grid-cols-2 gap-2 md:gap-6 py-0.5 opacity-0"
          >
            <div
              class="flex flex-col items-center justify-center px-2 imagen-izq"
            >
              <div
                class="w-10 h-10 md:w-12 md:h-12 transform transition-transform duration-300 hover:scale-110"
