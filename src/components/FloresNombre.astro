<div
    id="flores-nombre-wrapper"
    style="position:relative; display:inline-block; width:100%;"
>
    <img
        src="/imagenes/principal.png"
        alt="Principal"
        style="display:block; width:100%;"
    />
    <img
        src="/imagenes/florhorizontal.png"
        alt="Flores decorativas"
        style="position:absolute; bottom:-35px; left:0; width:100%; pointer-events:none; z-index:11;"
    />
    <canvas
        id="hadas-canvas"
        style="position:absolute; top:0; left:0; width:100%; height:100%; pointer-events:none; z-index:10;"
    ></canvas>
</div>

<script>
    (function () {
        const wrapper = document.getElementById("flores-nombre-wrapper");
        const canvas = document.getElementById(
            "hadas-canvas",
        ) as HTMLCanvasElement;
        const ctx = canvas.getContext("2d")!;

        function resize() {
            canvas.width = wrapper!.offsetWidth;
            canvas.height = wrapper!.offsetHeight;
        }
        resize();
        window.addEventListener("resize", resize);

        const TOTAL = 60;

        interface Hada {
            x: number;
            y: number;
            vx: number;
            vy: number;
            alpha: number;
            alphaDir: number;
            size: number;
            pulso: number;
            pulsoVel: number;
        }

        function nuevaHada(): Hada {
            return {
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                vx: (Math.random() - 0.5) * 0.5,
                vy: -(Math.random() * 0.5 + 0.2),
                alpha: Math.random(),
                alphaDir: Math.random() < 0.5 ? 0.008 : -0.008,
                size: Math.random() * 2.5 + 1,
                pulso: Math.random() * Math.PI * 2,
                pulsoVel: Math.random() * 0.04 + 0.02,
            };
        }

        const hadas: Hada[] = Array.from({ length: TOTAL }, () => nuevaHada());

        function dibujarDestello(
            x: number,
            y: number,
            r: number,
            alpha: number,
        ) {
            // Cruz de luz de 4 brazos con degradado
            const gradient = ctx.createRadialGradient(x, y, 0, x, y, r * 2.5);
            gradient.addColorStop(0, `rgba(255,255,255,${alpha})`);
            gradient.addColorStop(1, `rgba(255,255,255,0)`);

            ctx.save();
            ctx.globalAlpha = alpha;

            // Centro brillante
            ctx.beginPath();
            ctx.arc(x, y, r * 0.5, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(255,255,255,${alpha})`;
            ctx.fill();

            // Brazos largos (cruz de hada)
            ctx.strokeStyle = `rgba(255,255,255,${alpha * 0.7})`;
            ctx.lineWidth = r * 0.35;
            ctx.lineCap = "round";

            ctx.beginPath();
            ctx.moveTo(x, y - r * 2.5);
            ctx.lineTo(x, y + r * 2.5);
            ctx.stroke();

            ctx.beginPath();
            ctx.moveTo(x - r * 2.5, y);
            ctx.lineTo(x + r * 2.5, y);
            ctx.stroke();

            // Brazos diagonales más cortos
            ctx.lineWidth = r * 0.2;
            ctx.beginPath();
            ctx.moveTo(x - r * 1.4, y - r * 1.4);
            ctx.lineTo(x + r * 1.4, y + r * 1.4);
            ctx.stroke();

            ctx.beginPath();
            ctx.moveTo(x + r * 1.4, y - r * 1.4);
            ctx.lineTo(x - r * 1.4, y + r * 1.4);
            ctx.stroke();

            // Halo suave
            ctx.beginPath();
            ctx.arc(x, y, r * 2.5, 0, Math.PI * 2);
            ctx.fillStyle = gradient;
            ctx.fill();

            ctx.restore();
        }

        function animar() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            for (let i = 0; i < hadas.length; i++) {
                const h = hadas[i];

                h.x += h.vx + Math.sin(h.pulso) * 0.3;
                h.y += h.vy;
                h.pulso += h.pulsoVel;
                h.alpha += h.alphaDir;

                if (h.alpha >= 1) {
                    h.alpha = 1;
                    h.alphaDir = -0.008;
                }
                if (h.alpha <= 0) {
                    h.alpha = 0;
                    h.alphaDir = 0.008;
                }

                if (h.y < -10 || h.x < -10 || h.x > canvas.width + 10) {
                    hadas[i] = nuevaHada();
                    hadas[i].y = canvas.height + 5;
                    continue;
                }

                dibujarDestello(h.x, h.y, h.size, h.alpha);
            }

            requestAnimationFrame(animar);
        }

        animar();
    })();
</script>
